# ============================================================
# ArenaOS — .gitignore
# ============================================================

# compiled output
dist/
tmp/
out-tsc/
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules/

# environment variables — NEVER commit secrets
.env
.env.local
.env.*.local
*.env
.envrc

# IDEs
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.sublime-workspace
*.sublime-project

# system files
.DS_Store
Thumbs.db

# test coverage
coverage/
.nyc_output/

# build artifacts
*.log
npm-debug.log*
yarn-error.log*

# Replit platform — internal tooling, not needed in source control
.cache/
.local/
.cursor/
.github/
.replit
.replitignore
.replitdb/

# Media generated during testing / dev iteration
*.mp4
*.mov
*.webm
*.gif
